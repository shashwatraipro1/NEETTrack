  TASKS.forEach((t, i) => {
    g.innerHTML += `
    <div class="check-item" id="ci${i}" onclick="toggleCheck(${i})">
      <div class="cbox" id="cb${i}"><span class="ctick">✓</span></div>
      <span class="clabel">${t}</span>
    </div>`;
  });
}

function buildMoodGrid() {
  const g = document.getElementById('mood-grid');
  MOODS.forEach((m, i) => {
    g.innerHTML += `<button class="mood-btn" id="mood${i}" onclick="selMood('${m}')">${m}</button>`;
  });
}

/* ══════════════════ INTERACTIONS ══════════════════ */
function toggleCheck(i) { document.getElementById('ci' + i).classList.toggle('checked'); }
function selMood(m) {
  selectedMood = m;
  MOODS.forEach((_, i) => document.getElementById('mood' + i).classList.remove('sel'));
  const idx = MOODS.indexOf(m);
  if (idx >= 0) document.getElementById('mood' + idx).classList.add('sel');
}
function selTest(v) {
  selectedTest = v;
  ['yes', 'no'].forEach(x => document.getElementById('t-' + x).classList.remove('sel-yes', 'sel-no'));
  document.getElementById('t-' + v).classList.add('sel-' + v);
}
function updateScoreBadge(i) {
  // visual only — score stored on save
}
function onQChange() {
  const q = parseInt(document.getElementById('q-inp').value) || 0;
  document.getElementById('sv-q').textContent = q;
  computeAutoEfficiency();
}
function onHChange() {
  const h = parseFloat(document.getElementById('h-inp').value) || 0;
  document.getElementById('sv-h').textContent = h + 'h';
  computeAutoEfficiency();
}
function onEffChange() {
  const e = parseFloat(document.getElementById('eff-inp').value);
  if (e) {
    document.getElementById('sv-eff').textContent = e + '/10';
    document.getElementById('eff-fill').style.width = (e / 10 * 100) + '%';
  }
}

/* ══════════════════ EFFICIENCY CALC ══════════════════ */
function computeAutoEfficiency() {
  const q = parseInt(document.getElementById('q-inp').value) || 0;
  const h = parseFloat(document.getElementById('h-inp').value) || pomoFocusMin / 60;
  if (h <= 0) return;

  // Formula: base from q/h ratio + bonus from consecutive pomodoro sessions
  const qph = q / h; // questions per hour
  const baseScore = Math.min(10, qph / 8); // 80 q/h = score of 10
  const pomoBonusRaw = Math.min(3, pomoStreak * 0.5); // max +3 for 6 continuous sessions
  const raw = Math.min(10, baseScore + pomoBonusRaw);
  autoEfficiency = Math.round(raw * 10) / 10;

  const displayed = autoEfficiency.toFixed(1);
  document.getElementById('sv-eff').textContent = displayed + '/10';
  document.getElementById('eff-fill').style.width = (autoEfficiency / 10 * 100) + '%';
  document.getElementById('pi-eff').textContent = displayed + '/10';

  // don't override manual input
  const manualEff = document.getElementById('eff-inp').value;
  if (!manualEff) {
    document.getElementById('eff-inp').placeholder = 'Auto: ' + displayed;
  }
  document.getElementById('sync-eff-badge').textContent = displayed + '/10';
}

/* ══════════════════ POMODORO ══════════════════ */
function setMode(mode, mins) {
  if (pomoRunning) { clearInterval(pomoInterval); pomoRunning = false; }
  pomoMode = mode; pomoTotal = mins * 60; pomoLeft = mins * 60;
  document.querySelectorAll('.pomo-mode-btn').forEach(b => b.classList.remove('active'));
  document.querySelector(`.pomo-mode-btn[data-m="${mode}"]`).classList.add('active');
  const colors = { focus: '#7c6cf8', short: '#4ecdc4', long: '#f7c948' };
  document.getElementById('pomo-ring').style.stroke = colors[mode];
  document.getElementById('pomo-btn-icon').textContent = '▶';
  document.getElementById('pomo-btn-label').textContent = 'Start';
  document.getElementById('pomo-play-btn').classList.remove('paused');
  document.getElementById('pomo-card').classList.remove('pomo-running');
  updatePomoDisplay();
}

function toggleTimer() {
  if (pomoRunning) {
    clearInterval(pomoInterval); pomoRunning = false;
    document.getElementById('pomo-btn-icon').textContent = '▶';
    document.getElementById('pomo-btn-label').textContent = 'Resume';
    document.getElementById('pomo-play-btn').classList.add('paused');
    document.getElementById('pomo-card').classList.remove('pomo-running');
  } else {
    pomoRunning = true;
    document.getElementById('pomo-btn-icon').textContent = '⏸';
    document.getElementById('pomo-btn-label').textContent = 'Pause';
    document.getElementById('pomo-play-btn').classList.remove('paused');
    document.getElementById('pomo-card').classList.add('pomo-running');
    pomoInterval = setInterval(tick, 1000);
  }
}

function resetTimer() {
  clearInterval(pomoInterval); pomoRunning = false;
  pomoLeft = pomoTotal;
  document.getElementById('pomo-btn-icon').textContent = '▶';
  document.getElementById('pomo-btn-label').textContent = 'Start';
  document.getElementById('pomo-play-btn').classList.remove('paused');
  document.getElementById('pomo-card').classList.remove('pomo-running');
  updatePomoDisplay();
}

function skipTimer() {
  clearInterval(pomoInterval); pomoRunning = false;
  pomoLeft = 0;
  finishSession();
}

function tick() {
  if (pomoLeft <= 0) { finishSession(); return; }
  pomoLeft--;
  updatePomoDisplay();
}

function finishSession() {
  clearInterval(pomoInterval); pomoRunning = false;
  document.getElementById('pomo-card').classList.remove('pomo-running');
  playBeep();

  if (pomoMode === 'focus') {
    pomoSessions++;
    pomoStreak++;
    pomoFocusMin += 25;
    updateSyncedHours();
    computeAutoEfficiency();
    document.getElementById('p-count').textContent = pomoSessions;
    document.getElementById('p-total-min').textContent = pomoFocusMin + 'm';
    document.getElementById('pi-done').textContent = pomoSessions + ' sessions';
    document.getElementById('pi-focus').textContent = pomoFocusMin + ' min';
  } else {
    // Break done — maintain streak
  }
  updatePomoDots();
  // Auto-advance
  setTimeout(() => {
    if (pomoMode === 'focus') {
      setMode(pomoSessions % 4 === 0 ? 'long' : 'short', pomoSessions % 4 === 0 ? 15 : 5);
    } else {
      setMode('focus', 25);
    }
  }, 1200);
}

function updateSyncedHours() {
  const h = (pomoFocusMin / 60).toFixed(2);
  const displayH = Math.floor(pomoFocusMin / 60);
  const displayM = pomoFocusMin % 60;
  document.getElementById('sync-hours').textContent = displayH + 'h ' + displayM + 'm';
  document.getElementById('sv-h').textContent = parseFloat(h).toFixed(1) + 'h';
  // Sync to hours input
  document.getElementById('h-inp').value = parseFloat(h).toFixed(2);
  document.getElementById('sv-h-sync').textContent = 'synced ✓';
}

function updatePomoDisplay() {
  const m = String(Math.floor(pomoLeft / 60)).padStart(2, '0');
  const s = String(pomoLeft % 60).padStart(2, '0');
  document.getElementById('pomo-time').textContent = m + ':' + s;
  const modeLabels = { focus: 'Focus', short: 'Short Break', long: 'Long Break' };
  document.getElementById('pomo-mode-lbl').textContent = modeLabels[pomoMode];
  const circ = 2 * Math.PI * 70;
  const pct = 1 - (pomoLeft / pomoTotal);
  document.getElementById('pomo-ring').style.strokeDasharray = circ;
  document.getElementById('pomo-ring').style.strokeDashoffset = circ * pct;
  const nextMin = pomoMode === 'focus' ? (pomoSessions % 4 === 0 && pomoSessions > 0 ? 15 : 5) : 25;
  document.getElementById('pi-next').textContent = 'after this (' + nextMin + 'm)';
}

function updatePomoDots() {
  const d = document.getElementById('pomo-dots');
  d.innerHTML = '';
  for (let i = 0; i < 4; i++) {
    const done = i < (pomoSessions % 4) || (pomoSessions > 0 && pomoSessions % 4 === 0);
    d.innerHTML += `<div class="pdot ${done ? 'done' : ''}"></div>`;
  }
}

function playBeep() {
  try {
    const a = new (window.AudioContext || window.webkitAudioContext)();
    [880, 1100, 880].forEach((freq, i) => {
      const o = a.createOscillator(), g = a.createGain();
      o.connect(g); g.connect(a.destination);
      o.frequency.value = freq;
      const t = a.currentTime + i * 0.18;
      g.gain.setValueAtTime(0.25, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.15);
      o.start(t); o.stop(t + 0.15);
    });
  } catch (e) {}
}

/* ══════════════════ STREAK ══════════════════ */
function loadStreak() {
  try {
    const data = JSON.parse(localStorage.getItem(KEY('streak')) || '{"count":0,"last":""}');
    const today = todayStr();
    const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
    let streak = data.count;
    if (data.last !== today && data.last !== yesterday) streak = 0;
    document.getElementById('streak-num').textContent = streak;
    document.getElementById('sv-s').textContent = streak;
  } catch {}
}
function markStreak() {
  try {
    const data = JSON.parse(localStorage.getItem(KEY('streak')) || '{"count":0,"last":""}');
    const today = todayStr();
    const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
    let streak = (data.last === yesterday) ? data.count + 1 : (data.last === today ? data.count : 1);
    localStorage.setItem(KEY('streak'), JSON.stringify({ count: streak, last: today }));
    document.getElementById('streak-num').textContent = streak;
    document.getElementById('sv-s').textContent = streak;
  } catch {}
}

/* ══════════════════ SAVE / LOAD ══════════════════ */
function gatherData() {
  const tasks = TASKS.filter((_, i) => document.getElementById('ci' + i).classList.contains('checked'));
  const subjects = SUBJECTS.map((s, i) => ({
    name: s.name,
    topic: document.getElementById('topic' + i).value,
    teacher: document.getElementById('teacher' + i).value,
    score: document.getElementById('score' + i).value,
  }));
  const eff = parseFloat(document.getElementById('eff-inp').value) || autoEfficiency;
  return {
    date: document.getElementById('log-date') ? document.getElementById('log-date').value : todayStr(),
    questions: parseInt(document.getElementById('q-inp').value) || 0,
    hours: parseFloat(document.getElementById('h-inp').value) || 0,
    efficiency: eff,
    pomoSessions, pomoFocusMin,
    tasks, subjects,
    mood: selectedMood,
    test: selectedTest,
    improved: document.getElementById('improved-inp').value,
    regret: document.getElementById('regret-inp').value,
  };
}

function saveLog() {
  const btn = document.getElementById('save-btn');
  btn.textContent = 'Saving…';
  btn.classList.add('saving');
  setTimeout(() => {
    const data = gatherData();
    setLog(todayStr(), data);
    markStreak();
    renderCalendar();
    renderStats();
    btn.textContent = 'Saved! ✓';
    btn.classList.remove('saving');
    document.getElementById('save-toast').style.display = 'block';
    setTimeout(() => {
      btn.textContent = 'Save Today\'s Log';
      document.getElementById('save-toast').style.display = 'none';
    }, 3000);
  }, 600);
}

function loadTodayData() {
  const data = getLog(todayStr());
  if (!data) return;
  if (data.questions) { document.getElementById('q-inp').value = data.questions; document.getElementById('sv-q').textContent = data.questions; }
  if (data.hours) { document.getElementById('h-inp').value = data.hours; document.getElementById('sv-h').textContent = data.hours + 'h'; }
  if (data.efficiency) { document.getElementById('eff-inp').value = data.efficiency; document.getElementById('sv-eff').textContent = data.efficiency + '/10'; document.getElementById('eff-fill').style.width = (data.efficiency / 10 * 100) + '%'; }
  if (data.tasks) data.tasks.forEach(t => { const i = TASKS.indexOf(t); if (i >= 0) document.getElementById('ci' + i).classList.add('checked'); });
  if (data.subjects) data.subjects.forEach((s, i) => {
    if (document.getElementById('topic' + i)) document.getElementById('topic' + i).value = s.topic || '';
    if (document.getElementById('teacher' + i)) document.getElementById('teacher' + i).value = s.teacher || '';
    if (document.getElementById('score' + i)) document.getElementById('score' + i).value = s.score || '';
  });
  if (data.mood) selMood(data.mood);
  if (data.test) selTest(data.test);
  if (data.improved) document.getElementById('improved-inp').value = data.improved;
  if (data.regret) document.getElementById('regret-inp').value = data.regret;
  if (data.pomoSessions) { pomoSessions = data.pomoSessions; pomoFocusMin = data.pomoFocusMin || 0; document.getElementById('p-count').textContent = pomoSessions; document.getElementById('p-total-min').textContent = pomoFocusMin + 'm'; updatePomoDots(); }
}

/* ══════════════════ CALENDAR ══════════════════ */
function renderCalendar() {
  const title = new Date(calYear, calMonth).toLocaleDateString('en-IN', { month: 'long', year: 'numeric' });
  document.getElementById('cal-title').textContent = title;
  const allLogs = getAllLogs();
  const today = todayStr();
  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
  let html = '';
  for (let i = 0; i < firstDay; i++) html += `<div class="cal-day empty"></div>`;
  for (let d = 1; d <= daysInMonth; d++) {
    const dateStr = `${calYear}-${String(calMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
    const log = allLogs[dateStr];
    const isToday = dateStr === today;
    let dotClass = '';
    if (log) dotClass = (log.hours >= 6 || log.questions >= 80) ? 'done' : 'partial';
    html += `<div class="cal-day${isToday ? ' today' : ''}${log ? ' has-data' : ''}" onclick="showDayDetail('${dateStr}')">
      <span class="cal-day-num">${d}</span>
      ${log ? `<div class="cal-day-dot ${dotClass}"></div>` : ''}
    </div>`;
  }
  document.getElementById('cal-days').innerHTML = html;
}

function calNav(dir) {
  calMonth += dir;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
  closeDetail();
}

function showDayDetail(dateStr) {
  const log = getLog(dateStr);
  const det = document.getElementById('day-detail');
  document.getElementById('dd-title').textContent = formatDate(dateStr);
  det.classList.add('visible');
  const c = document.getElementById('dd-content');
  if (!log) {
    c.innerHTML = `<div class="no-data-msg">No study log for this day.<br><span style="color:var(--muted);font-size:12px">Keep grinding — today counts!</span></div>`;
    return;
  }
  const eff = log.efficiency ? log.efficiency.toFixed(1) : '—';
  c.innerHTML = `
    <div class="detail-grid">
      <div class="detail-item"><div class="detail-item-lbl">Questions</div><div class="detail-item-val" style="color:var(--teal)">${log.questions || 0}</div></div>
      <div class="detail-item"><div class="detail-item-lbl">Hours</div><div class="detail-item-val" style="color:var(--warn)">${log.hours || 0}h</div></div>
      <div class="detail-item"><div class="detail-item-lbl">Efficiency</div><div class="detail-item-val" style="color:var(--accent)">${eff}/10</div></div>
      <div class="detail-item"><div class="detail-item-lbl">Pomodoros</div><div class="detail-item-val" style="color:var(--green)">${log.pomoSessions || 0}</div></div>
    </div>
    <div class="detail-subjects">
      ${(log.subjects || []).filter(s => s.topic).map(s => `
        <div class="detail-subj-row">
          <span style="font-weight:600">${s.name}</span>
          <span style="color:var(--muted2)">${s.topic}</span>
          ${s.score ? `<span style="color:var(--green)">${s.score}%</span>` : ''}
        </div>`).join('')}
    </div>
    ${log.tasks && log.tasks.length ? `<div class="detail-tasks">${log.tasks.map(t => `<span class="task-pill">${t}</span>`).join('')}</div>` : ''}
    ${log.mood ? `<div style="margin-bottom:8px;font-size:13px;color:var(--muted2)">Mood: <b style="color:var(--text)">${log.mood}</b>${log.test ? `  |  Test: <b>${log.test}</b>` : ''}</div>` : ''}
    ${log.improved ? `<div class="detail-note" style="margin-bottom:8px"><b style="color:var(--green);font-size:11px">IMPROVED</b><br>${log.improved}</div>` : ''}
    ${log.regret ? `<div class="detail-note"><b style="color:var(--red);font-size:11px">REGRET</b><br>${log.regret}</div>` : ''}
  `;
  // Highlight selected day
  document.querySelectorAll('.cal-day').forEach(el => el.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
}

function closeDetail() {
  document.getElementById('day-detail').classList.remove('visible');
  document.querySelectorAll('.cal-day').forEach(el => el.classList.remove('selected'));
}

/* ══════════════════ STATS PAGE ══════════════════ */
function renderStats() {
  const allLogs = getAllLogs();
  const entries = Object.values(allLogs);
  if (!entries.length) return;
  const totalH = entries.reduce((s, l) => s + (l.hours || 0), 0);
  const totalQ = entries.reduce((s, l) => s + (l.questions || 0), 0);
  const effs = entries.filter(l => l.efficiency).map(l => l.efficiency);
  const avgEff = effs.length ? (effs.reduce((a, b) => a + b, 0) / effs.length).toFixed(1) : '—';
  document.getElementById('so-total-h').textContent = totalH.toFixed(1) + 'h';
  document.getElementById('so-total-q').textContent = totalQ;
  document.getElementById('so-avg-eff').textContent = avgEff !== '—' ? avgEff + '/10' : '—';

  // 7-day bar charts
  const days = [];
  for (let i = 6; i >= 0; i--) {
    const d = new Date(Date.now() - i * 86400000);
    const ds = d.toISOString().split('T')[0];
    const log = allLogs[ds] || {};
    days.push({ label: d.toLocaleDateString('en-IN', { weekday: 'short' }), h: log.hours || 0, q: log.questions || 0, isToday: ds === todayStr() });
  }
  const maxH = Math.max(...days.map(d => d.h), 1);
  const maxQ = Math.max(...days.map(d => d.q), 1);
  document.getElementById('week-bars').innerHTML = days.map(d => `
    <div class="bar-col">
      <div class="bar-val">${d.h > 0 ? d.h.toFixed(1) : ''}</div>
      <div class="bar-fill${d.isToday ? ' today' : ''}" style="height:${(d.h / maxH * 80)}px"></div>
      <div class="bar-lbl">${d.label}</div>
    </div>`).join('');
  document.getElementById('week-q-bars').innerHTML = days.map(d => `
    <div class="bar-col">
      <div class="bar-val" style="color:var(--teal);font-size:10px">${d.q > 0 ? d.q : ''}</div>
      <div class="bar-fill${d.isToday ? ' today' : ''}" style="height:${(d.q / maxQ * 80)}px;background:var(--teal)"></div>
      <div class="bar-lbl">${d.label}</div>
    </div>`).join('');

  // Personal bests
  const bestH = Math.max(...entries.map(l => l.hours || 0));
  const bestQ = Math.max(...entries.map(l => l.questions || 0));
  const bestEff = effs.length ? Math.max(...effs) : null;
  const bestPomo = Math.max(...entries.map(l => l.pomoSessions || 0));
  document.getElementById('pb-content').innerHTML = [
    { lbl: '⏰ Most study hours in a day', val: bestH + 'h' },
    { lbl: '📝 Most questions in a day', val: bestQ },
    { lbl: '⚡ Best efficiency score', val: bestEff ? bestEff + '/10' : '—' },
    { lbl: '🍅 Most pomodoros in a day', val: bestPomo },
  ].map(pb => `<div style="display:flex;justify-content:space-between;padding:10px 12px;background:var(--s2);border:1px solid var(--border);border-radius:var(--r);font-size:13px"><span style="color:var(--muted2)">${pb.lbl}</span><span style="font-weight:700;font-family:var(--font)">${pb.val}</span></div>`).join('');
}

/* ══════════════════ NAVIGATION ══════════════════ */
function switchPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  const idx = ['today', 'calendar', 'stats'].indexOf(id);
  document.querySelectorAll('.nav-tab')[idx].classList.add('active');
  if (id === 'stats') renderStats();
  if (id === 'calendar') renderCalendar();
}

/* ══════════════════ START ══════════════════ */
init();
</script>


