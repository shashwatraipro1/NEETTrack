<html lang="en"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEETTrack — Study Command Center</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&amp;family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&amp;display=swap" rel="stylesheet">
<style>
/* ── RESET & BASE ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07070d;
  --s1:#0f0f18;
  --s2:#161622;
  --s3:#1e1e2e;
  --border:#252538;
  --border2:#303048;
  --text:#eeeef8;
  --muted:#5a5a7a;
  --muted2:#7a7a9a;
  --accent:#7c6cf8;
  --accent-dim:rgba(124,108,248,0.12);
  --accent-glow:rgba(124,108,248,0.25);
  --teal:#4ecdc4;
  --teal-dim:rgba(78,205,196,0.12);
  --warn:#f7c948;
  --warn-dim:rgba(247,201,72,0.1);
  --green:#5ce87a;
  --green-dim:rgba(92,232,122,0.1);
  --red:#ff6b6b;
  --red-dim:rgba(255,107,107,0.1);
  --font:'Syne',sans-serif;
  --body:'DM Sans',sans-serif;
  --r:12px;
  --r2:18px;
  --r3:24px;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--body);min-height:100vh;font-size:14px;line-height:1.6}
input,textarea,select,button{font-family:var(--body);font-size:14px}
button{cursor:pointer}

/* ── LAYOUT ── */
.app{max-width:780px;margin:0 auto;padding:1.5rem 1rem 4rem}

/* ── TOPBAR ── */
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border)}
.logo{font-family:var(--font);font-size:1.5rem;font-weight:800;letter-spacing:-1px;display:flex;align-items:center;gap:8px}
.logo .dot{width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 10px var(--accent)}
.logo span{color:var(--accent)}
.topbar-right{display:flex;align-items:center;gap:10px}
.date-chip{background:var(--s2);border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:12px;color:var(--muted2);font-weight:500}
.streak-chip{background:var(--warn-dim);border:1px solid rgba(247,201,72,0.2);border-radius:20px;padding:6px 14px;font-size:12px;color:var(--warn);font-weight:600;display:flex;align-items:center;gap:5px}

/* ── NAV TABS ── */
.nav-tabs{display:flex;gap:4px;background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:4px;margin-bottom:1.5rem}
.nav-tab{flex:1;padding:8px 12px;border-radius:var(--r);border:none;background:transparent;color:var(--muted2);font-size:13px;font-weight:500;font-family:var(--font);transition:all 0.2s;cursor:pointer}
.nav-tab.active{background:var(--s3);color:var(--text);border:1px solid var(--border2)}
.nav-tab:hover:not(.active){color:var(--text)}

/* ── PAGES ── */
.page{display:none}
.page.active{display:block}

/* ── QUOTE STRIP ── */
.quote-strip{background:linear-gradient(135deg,rgba(124,108,248,0.08) 0%,rgba(78,205,196,0.05) 100%);border:1px solid rgba(124,108,248,0.2);border-radius:var(--r2);padding:1.2rem 1.4rem;margin-bottom:1.2rem;position:relative;overflow:hidden}
.quote-strip::before{content:'';position:absolute;top:-40px;right:-40px;width:150px;height:150px;border-radius:50%;background:rgba(124,108,248,0.08);filter:blur(40px)}
.q-text{font-family:var(--font);font-size:0.95rem;font-weight:500;line-height:1.5;margin-bottom:4px}
.q-src{font-size:11px;color:var(--muted);font-style:italic}

/* ── POMODORO ── */
.pomo-card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r3);padding:1.8rem 1.4rem;margin-bottom:1.2rem}
.pomo-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.4rem}
.pomo-title{font-family:var(--font);font-size:15px;font-weight:700;letter-spacing:-0.3px}
.pomo-stats-mini{display:flex;gap:8px}
.pomo-stat-pill{background:var(--s2);border:1px solid var(--border);border-radius:20px;padding:4px 10px;font-size:11px;color:var(--muted2)}
.pomo-stat-pill b{color:var(--text);font-weight:600}

.pomo-mode-tabs{display:flex;gap:6px;margin-bottom:1.4rem}
.pomo-mode-btn{flex:1;padding:8px;border-radius:var(--r);border:1px solid var(--border);background:var(--s2);color:var(--muted2);font-size:12px;font-weight:600;font-family:var(--font);transition:all 0.2s}
.pomo-mode-btn.active[data-m="focus"]{background:var(--accent-dim);border-color:rgba(124,108,248,0.4);color:var(--accent)}
.pomo-mode-btn.active[data-m="short"]{background:var(--teal-dim);border-color:rgba(78,205,196,0.4);color:var(--teal)}
.pomo-mode-btn.active[data-m="long"]{background:var(--warn-dim);border-color:rgba(247,201,72,0.3);color:var(--warn)}
.pomo-mode-btn:hover:not(.active){border-color:var(--border2);color:var(--text)}

.pomo-timer-wrap{display:flex;align-items:center;gap:2rem;flex-wrap:wrap}
.pomo-circle-wrap{position:relative;width:160px;height:160px;flex-shrink:0}
.pomo-svg{width:100%;height:100%;transform:rotate(-90deg)}
.pomo-track{fill:none;stroke:var(--border);stroke-width:6}
.pomo-ring{fill:none;stroke:var(--accent);stroke-width:6;stroke-linecap:round;stroke-dasharray:440;stroke-dashoffset:0;transition:stroke-dashoffset 0.9s linear,stroke 0.3s}
.pomo-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.pomo-time-big{font-family:var(--font);font-size:2.4rem;font-weight:800;letter-spacing:-2px;line-height:1}
.pomo-mode-lbl{font-size:11px;color:var(--muted2);margin-top:3px;text-transform:uppercase;letter-spacing:1px}

.pomo-right{flex:1;min-width:180px}
.pomo-info-row{display:flex;flex-direction:column;gap:8px;margin-bottom:1rem}
.pomo-info-item{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--muted2)}
.pomo-info-item span:last-child{color:var(--text);font-weight:600}
.pomo-dots-row{display:flex;gap:5px;margin-bottom:1rem}
.pdot{width:12px;height:12px;border-radius:3px;background:var(--border);transition:all 0.3s}
.pdot.done{background:var(--accent)}
.pdot.half{background:var(--border2)}

.pomo-controls{display:flex;gap:8px}
.btn-pomo-play{flex:1;padding:11px;border-radius:var(--r);border:1px solid var(--accent);background:var(--accent);color:#fff;font-weight:700;font-family:var(--font);font-size:14px;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:6px}
.btn-pomo-play:hover{background:rgba(124,108,248,0.85)}
.btn-pomo-play.paused{background:transparent;color:var(--accent)}
.btn-ico{width:38px;height:38px;border-radius:var(--r);border:1px solid var(--border);background:var(--s2);color:var(--muted2);display:flex;align-items:center;justify-content:center;font-size:16px;transition:all 0.2s}
.btn-ico:hover{border-color:var(--border2);color:var(--text)}

/* Sync bar */
.sync-bar{background:var(--s2);border:1px solid var(--border);border-radius:var(--r);padding:10px 14px;margin-top:10px;display:flex;align-items:center;gap:10px;font-size:12px;color:var(--muted2)}
.sync-bar .sync-icon{font-size:14px}
.sync-bar b{color:var(--teal)}
.sync-badge{background:var(--teal-dim);border:1px solid rgba(78,205,196,0.25);color:var(--teal);padding:2px 8px;border-radius:6px;font-size:11px;font-weight:600;margin-left:auto}

/* ── SECTION CARD ── */
.scard{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:1.3rem 1.2rem;margin-bottom:1.2rem}
.scard-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.1rem}
.scard-title{font-family:var(--font);font-size:14px;font-weight:700;letter-spacing:-0.3px;display:flex;align-items:center;gap:8px}
.scard-badge{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}

/* ── CLASS TRACKER ── */
.subj-header{display:grid;grid-template-columns:90px 1fr 1fr 80px;gap:8px;padding:0 4px;margin-bottom:6px}
.subj-header span{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted)}
.subj-row{display:grid;grid-template-columns:90px 1fr 1fr 80px;gap:8px;margin-bottom:8px;align-items:center}
.subj-label{display:flex;align-items:center;gap:6px;padding:0 2px}
.subj-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.subj-name{font-size:13px;font-weight:600;font-family:var(--font)}
.inp{background:var(--s2);border:1px solid var(--border);color:var(--text);border-radius:var(--r);padding:9px 12px;font-size:13px;font-family:var(--body);width:100%;transition:border-color 0.2s,background 0.2s;outline:none}
.inp:focus{border-color:var(--accent);background:rgba(124,108,248,0.05)}
.inp::placeholder{color:var(--muted)}
.inp-sm{padding:7px 10px;font-size:12px;text-align:center}
.marks-badge{background:var(--s3);border:1px solid var(--border);border-radius:var(--r);padding:6px 10px;text-align:center;font-size:13px;font-weight:700;color:var(--muted2);width:100%}
.marks-badge.good{color:var(--green);background:var(--green-dim);border-color:rgba(92,232,122,0.2)}
.marks-badge.ok{color:var(--warn);background:var(--warn-dim);border-color:rgba(247,201,72,0.2)}
.marks-badge.bad{color:var(--red);background:var(--red-dim);border-color:rgba(255,107,107,0.2)}

/* ── TASK CHECKS ── */
.check-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.check-item{display:flex;align-items:center;gap:10px;background:var(--s2);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px;cursor:pointer;transition:all 0.15s;user-select:none}
.check-item:hover{border-color:var(--border2)}
.check-item.checked{background:var(--accent-dim);border-color:rgba(124,108,248,0.35)}
.cbox{width:20px;height:20px;border-radius:6px;border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.15s;background:transparent}
.check-item.checked .cbox{background:var(--accent);border-color:var(--accent)}
.ctick{color:#fff;font-size:12px;opacity:0;transition:opacity 0.1s}
.check-item.checked .ctick{opacity:1}
.clabel{font-size:13px;font-weight:500}

/* ── STATS GRID ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:1.2rem}
.stat-box{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:1rem;text-align:center}
.stat-val{font-family:var(--font);font-size:1.5rem;font-weight:800;letter-spacing:-1px;line-height:1.1}
.stat-lbl{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-top:4px}
.stat-sub{font-size:11px;color:var(--muted2);margin-top:2px}

/* ── EFFICIENCY METER ── */
.eff-meter{margin-top:8px}
.eff-bar-track{background:var(--border);border-radius:4px;height:6px;overflow:hidden}
.eff-bar-fill{height:100%;border-radius:4px;background:var(--accent);transition:width 0.5s cubic-bezier(.4,0,.2,1)}
.eff-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-top:4px}

/* ── MOOD ── */
.mood-grid{display:flex;gap:6px;flex-wrap:wrap}
.mood-btn{padding:8px 14px;border-radius:20px;border:1px solid var(--border);background:var(--s2);color:var(--muted2);font-size:12px;font-weight:500;transition:all 0.15s}
.mood-btn:hover{border-color:var(--border2);color:var(--text)}
.mood-btn.sel{background:var(--accent-dim);border-color:rgba(124,108,248,0.4);color:var(--text)}

/* ── FIELD HELPERS ── */
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.field{margin-bottom:10px}
.field-lbl{font-size:11px;text-transform:uppercase;letter-spacing:0.8px;color:var(--muted);margin-bottom:6px;display:block}
textarea.inp{min-height:70px;resize:vertical}

/* ── TEST TOGGLE ── */
.toggle-group{display:flex;gap:6px}
.toggle-btn{flex:1;padding:9px;border-radius:var(--r);border:1px solid var(--border);background:var(--s2);color:var(--muted2);font-weight:600;font-size:13px;transition:all 0.15s}
.toggle-btn:hover{border-color:var(--border2);color:var(--text)}
.toggle-btn.sel-yes{background:var(--green-dim);border-color:rgba(92,232,122,0.35);color:var(--green)}
.toggle-btn.sel-no{background:var(--red-dim);border-color:rgba(255,107,107,0.3);color:var(--red)}

/* ── SAVE BUTTON ── */
.save-wrap{margin-top:1.5rem}
.btn-save{width:100%;padding:15px;border-radius:var(--r2);border:none;background:var(--accent);color:#fff;font-family:var(--font);font-size:15px;font-weight:700;letter-spacing:0.3px;transition:all 0.2s;position:relative;overflow:hidden}
.btn-save::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.08),transparent);pointer-events:none}
.btn-save:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(124,108,248,0.3)}
.btn-save:active{transform:scale(0.99)}
.btn-save.saving{opacity:0.7}
.toast{margin-top:10px;background:var(--green-dim);border:1px solid rgba(92,232,122,0.25);color:var(--green);border-radius:var(--r);padding:12px;text-align:center;font-size:13px;font-weight:500;display:none}

/* ── CALENDAR PAGE ── */
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem}
.cal-nav{display:flex;align-items:center;gap:12px}
.cal-month-title{font-family:var(--font);font-size:1.2rem;font-weight:700;letter-spacing:-0.5px;min-width:160px;text-align:center}
.btn-cal-nav{width:34px;height:34px;border-radius:10px;border:1px solid var(--border);background:var(--s2);color:var(--muted2);display:flex;align-items:center;justify-content:center;font-size:16px;transition:all 0.15s}
.btn-cal-nav:hover{border-color:var(--border2);color:var(--text)}
.cal-grid{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;margin-bottom:1.2rem}
.cal-weekdays{display:grid;grid-template-columns:repeat(7,1fr);background:var(--s2);border-bottom:1px solid var(--border)}
.cal-wd{text-align:center;padding:10px 4px;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);font-weight:600}
.cal-days{display:grid;grid-template-columns:repeat(7,1fr)}
.cal-day{min-height:52px;padding:6px 5px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);position:relative;cursor:pointer;transition:background 0.15s;display:flex;flex-direction:column;align-items:center}
.cal-day:nth-child(7n){border-right:none}
.cal-day:hover:not(.empty){background:var(--s2)}
.cal-day.empty{cursor:default;background:rgba(0,0,0,0.15)}
.cal-day.today{background:var(--accent-dim)}
.cal-day.today .cal-day-num{color:var(--accent);font-weight:700}
.cal-day.has-data::after{content:'';width:5px;height:5px;border-radius:50%;background:var(--accent);margin-top:2px}
.cal-day.selected{background:var(--accent-dim);outline:2px solid rgba(124,108,248,0.5);outline-offset:-2px}
.cal-day-num{font-size:13px;font-weight:500;color:var(--muted2);line-height:1}
.cal-day-dot{width:4px;height:4px;border-radius:50%;margin-top:3px}
.cal-day-dot.done{background:var(--green)}
.cal-day-dot.partial{background:var(--warn)}

.day-detail{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:1.3rem;display:none}
.day-detail.visible{display:block}
.day-detail-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.day-detail-title{font-family:var(--font);font-size:1rem;font-weight:700}
.detail-close{width:28px;height:28px;border-radius:8px;border:1px solid var(--border);background:var(--s2);color:var(--muted2);display:flex;align-items:center;justify-content:center;font-size:14px}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.detail-item{background:var(--s2);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px}
.detail-item-lbl{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:4px}
.detail-item-val{font-family:var(--font);font-size:1rem;font-weight:700}
.detail-subjects{margin-bottom:12px}
.detail-subj-row{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px}
.detail-subj-row:last-child{border-bottom:none}
.detail-tasks{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
.task-pill{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;background:var(--accent-dim);border:1px solid rgba(124,108,248,0.2);color:var(--accent)}
.detail-note{font-size:13px;color:var(--muted2);line-height:1.6;padding:10px 12px;background:var(--s2);border-radius:var(--r);border:1px solid var(--border)}
.no-data-msg{text-align:center;padding:2rem;color:var(--muted);font-size:13px}

/* ── STATS PAGE ── */
.stats-overview{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:1.2rem}
.stat-overview-card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:1.2rem}
.sov-val{font-family:var(--font);font-size:1.8rem;font-weight:800;letter-spacing:-1px}
.sov-lbl{font-size:11px;color:var(--muted2);margin-top:2px}
.sov-trend{font-size:11px;margin-top:6px}
.trend-up{color:var(--green)}
.trend-dn{color:var(--red)}
.week-chart{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:1.2rem;margin-bottom:1.2rem}
.wchart-title{font-family:var(--font);font-size:13px;font-weight:700;margin-bottom:1rem}
.bar-chart{display:flex;align-items:flex-end;gap:6px;height:100px}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.bar-fill{width:100%;border-radius:4px 4px 0 0;background:var(--accent);min-height:2px;transition:height 0.4s ease;opacity:0.7}
.bar-fill.today{opacity:1;background:var(--accent)}
.bar-lbl{font-size:10px;color:var(--muted);text-align:center}
.bar-val{font-size:10px;color:var(--muted2);font-weight:600}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.page.active{animation:fadeUp 0.25s ease}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.6}}
.pomo-running .pomo-time-big{animation:pulse 2s ease infinite}
</style>
</head>
<body>
<div class="app">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="logo"><div class="dot"></div>NEET<span>Track</span></div>
    <div class="topbar-right">
      <div class="streak-chip">🔥 <span id="streak-num">2</span> day streak</div>
      <div class="date-chip" id="top-date">Thu, 23 Apr</div>
    </div>
  </div>

  <!-- NAV -->
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="switchPage('today')">Today</button>
    <button class="nav-tab" onclick="switchPage('calendar')">Calendar</button>
    <button class="nav-tab" onclick="switchPage('stats')">Stats</button>
  </div>

  <!-- ════ PAGE: TODAY ════ -->
  <div class="page active" id="page-today">

    <!-- QUOTE -->
    <div class="quote-strip">
      <div class="q-text" id="daily-quote">"Hard work beats talent when talent doesn't work hard."</div>
      <div class="q-src" id="daily-src">— Tim Notke</div>
    </div>

    <!-- POMODORO -->
    <div class="pomo-card" id="pomo-card">
      <div class="pomo-top">
        <div class="pomo-title">Pomodoro Timer</div>
        <div class="pomo-stats-mini">
          <div class="pomo-stat-pill">Sessions: <b id="p-count">0</b></div>
          <div class="pomo-stat-pill">Focus: <b id="p-total-min">0m</b></div>
        </div>
      </div>
      <div class="pomo-mode-tabs">
        <button class="pomo-mode-btn active" data-m="focus" onclick="setMode('focus',25)">🎯 Focus 25m</button>
