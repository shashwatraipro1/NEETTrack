<script>
/* ══════════════════ DATA HELPERS ══════════════════ */
const KEY = k => 'neettrack_' + k;
function getLog(date) {
  try { return JSON.parse(localStorage.getItem(KEY('log_' + date)) || 'null'); } catch { return null; }
}
function setLog(date, data) {
  localStorage.setItem(KEY('log_' + date), JSON.stringify(data));
}
function getAllLogs() {
  const logs = {};
  for (let i = 0; i < localStorage.length; i++) {
    const k = localStorage.key(i);
    if (k && k.startsWith(KEY('log_'))) {
      const date = k.replace(KEY('log_'), '');
      try { logs[date] = JSON.parse(localStorage.getItem(k)); } catch {}
    }
  }
  return logs;
}

function getTodayIST() {
  const now = new Date();
  const offset = now.getTimezoneOffset();
  const istTime = new Date(now.getTime() + (330 - offset) * 60000);
  return istTime.toISOString().split('T')[0];
}
function todayStr() { return new Date().toISOString().split('T')[0]; }
function formatDate(d) {
  return new Date(d + 'T12:00:00').toLocaleDateString('en-IN', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}

